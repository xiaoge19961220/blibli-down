{
  "name": "biliarchiver",
  "private": true,
  "version": "1.1.4",
  "type": "module",
  "main": "electron-main.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaoge19961220/blibli-down.git"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "desktop:dev": "electron .",
    "desktop:build": "npm run build && electron-builder",
    "release": "npm version patch",
    "postversion": "git push && git push --tags"
  },
  "build": {
    "appId": "com.biliarchiver.media",
    "productName": "BiliArchiver",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "xiaoge19961220",
        "repo": "blibli-down",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video",
      "icon": "assets/icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "differentialPackage": false
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
